{
  "name": "kondukt",
  "version": "0.1.2",
  "description": "MCP DevTools — test, validate, debug, and scaffold MCP servers for Claude Code, Codex, Gemini CLI, and any MCP client.",
  "type": "module",
  "license": "MIT",
  "author": "kondukt-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/kondukt-dev/core.git"
  },
  "homepage": "https://kondukt.dev",
  "bugs": "https://github.com/kondukt-dev/core/issues",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js",
    "./server": "./dist/server/index.js",
    "./validator": "./dist/validator/index.js",
    "./scaffold": "./dist/scaffold/index.js",
    "./agent-docs": "./dist/agent-docs/index.js",
    "./claudemd": "./dist/claudemd/index.js"
  },
  "bin": {
    "kondukt": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "devtools",
    "cli",
    "testing",
    "validation",
    "scaffold",
    "claude",
    "claude-code",
    "codex",
    "gemini",
    "ai",
    "agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "debug": "^4.4.0",
    "handlebars": "^4.7.9",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "execa": "^9.5.0",
    "prettier": "^3.4.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
